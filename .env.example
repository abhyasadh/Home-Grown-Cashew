# Cashew Server Configuration
# Copy this file to .env and update the values before running `docker compose up -d`

# Required: A strong random string used to sign JWT tokens.
# If left empty, the server will generate a random secret on every restart,
# which will invalidate all existing login sessions.
JWT_SECRET=change-me-to-a-long-random-string

# Optional: The port the server will listen on (default: 2580)
PORT=2580

# Optional: Directory on the host where the SQLite database and uploaded files are stored.
# Relative paths are resolved from the directory containing docker-compose.yml.
DATA_DIR=./data

# Optional: Directory inside the container that serves the Flutter web build.
# You usually do not need to change this.
WEB_DIR=/app/web/build
